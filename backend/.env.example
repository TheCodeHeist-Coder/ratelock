# Backend configuration (copy to .env for local `npm run dev`)

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ratelock

# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# Auth
JWT_SECRET=change-me-in-production

# Redis (rate-limit engine hot path)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=thisistheredislocalpassword
